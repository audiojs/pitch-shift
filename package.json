{
  "version": "1.0.0",
  "name": "@audio/shift",
  "type": "module",
  "types": "index.d.ts",
  "description": "Canonical pitch-shifting algorithms: phase vocoder, peak-locked, transient-aware, PSOLA, WSOLA, granular, PaulStretch, SMS, HPSS, formant, sampler, hybrid",
  "sideEffects": false,
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "license.md",
    "index.js",
    "index.d.ts",
    "pitch-shift.js"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node test.js",
    "quality": "node scripts/quality.js",
    "quality:ci": "node scripts/quality.js --ci",
    "bench": "node scripts/bench.js",
    "prepublishOnly": "node test.js && node scripts/quality.js --ci"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/pitch-shift.git"
  },
  "keywords": [
    "pitch-shift",
    "pitch-shifting",
    "phase-vocoder",
    "peak-locked",
    "transient",
    "psola",
    "wsola",
    "formant",
    "granular",
    "paulstretch",
    "sms",
    "sinusoidal",
    "hpss",
    "sampler",
    "hybrid",
    "variable-pitch",
    "audio",
    "dsp",
    "signal-processing"
  ],
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/audiojs/pitch-shift/issues"
  },
  "homepage": "https://github.com/audiojs/pitch-shift#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@audio/shift-core": "*",
    "@audio/shift-formant": "*",
    "@audio/shift-granular": "*",
    "@audio/shift-hpss": "*",
    "@audio/shift-hybrid": "*",
    "@audio/shift-ola": "*",
    "@audio/shift-paulstretch": "*",
    "@audio/shift-psola": "*",
    "@audio/shift-pvoc": "*",
    "@audio/shift-pvoc-lock": "*",
    "@audio/shift-sample": "*",
    "@audio/shift-sms": "*",
    "@audio/shift-transient": "*",
    "@audio/shift-wsola": "*",
    "fourier-transform": "^2.3.0",
    "time-stretch": "^1.2.1"
  },
  "devDependencies": {
    "audio-lena": "^3.0.0",
    "tst": "^9.4.0"
  }
}
